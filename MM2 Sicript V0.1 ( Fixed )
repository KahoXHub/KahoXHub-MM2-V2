local function CreateToggle(parent, text, pos, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0, 0, 0, pos)
    btn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
    btn.Font = Enum.Font.GothamBold
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 14
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            btn.BackgroundColor3 = Color3.fromRGB(40, 200, 40)
            btn.Text = text .. ": ON"
        else
            btn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
            btn.Text = text .. ": OFF"
        end
        callback(state)
    end)
end

--// SEKME 1: ESP //--
CreateToggle(ContainerESP, "PLAYER & GUN ESP", 10, function(val) EspActive = val end)
RunService.RenderStepped:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local highlight = p.Character:FindFirstChild("KahoX_Highlight")
            if EspActive then
                if not highlight then
                    highlight = Instance.new("Highlight", p.Character)
                    highlight.Name = "KahoX_Highlight"
                    highlight.FillTransparency = 0.4
                end
                local role = GetPlayerRole(p)
                if role == "Murderer" then highlight.FillColor = Color3.fromRGB(255, 0, 0)
                elseif role == "Sheriff" then highlight.FillColor = Color3.fromRGB(0, 100, 255)
                elseif role == "Hero" then highlight.FillColor = Color3.fromRGB(255, 255, 0)
                else highlight.FillColor = Color3.fromRGB(0, 255, 0) end
            elseif highlight then highlight:Destroy() end
        end
    end
    local gunDrop = Workspace:FindFirstChild("GunDrop")
    local visualSphere = Workspace:FindFirstChild("KahoX_GunSphere")
    if EspActive and gunDrop then
        if not visualSphere then
            visualSphere = Instance.new("Part", Workspace)
            visualSphere.Name = "KahoX_GunSphere"
            visualSphere.Shape = Enum.PartType.Ball
            visualSphere.Size = Vector3.new(5, 5, 5)
            visualSphere.Color = Color3.fromRGB(0, 150, 255)
            visualSphere.Transparency = 0.6
            visualSphere.Anchored = true
            visualSphere.CanCollide = false
        end
        visualSphere.CFrame = gunDrop:GetPivot()
    elseif visualSphere then visualSphere:Destroy() end
end)

--// SEKME 2: FLING //--
CreateToggle(ContainerFling, "LOOP FLING KILLER", 10, function(val) FlingKillerActive = val end)
CreateToggle(ContainerFling, "LOOP FLING SHERIFF", 60, function(val) FlingSheriffActive = val end)
CreateToggle(ContainerFling, "LOOP FLING ALL", 110, function(val) FlingAllActive = val end)

RunService.Stepped:Connect(function()
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myHrp = myChar.HumanoidRootPart
    local target = nil
    if FlingKillerActive then
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and GetPlayerRole(p) == "Murderer" then target = p.Character break end end
    elseif FlingSheriffActive then
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and (GetPlayerRole(p) == "Sheriff" or GetPlayerRole(p) == "Hero") then target = p.Character break end end
    elseif FlingAllActive then
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then target = p.Character break end end
    end
    if target and target:FindFirstChild("HumanoidRootPart") then
        if not IsFlinging then OriginalCFrame = myHrp.CFrame IsFlinging = true end
        for _, part in pairs(myChar:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
        myHrp.CFrame = target.HumanoidRootPart.CFrame
        myHrp.RotVelocity = Vector3.new(0, 50000, 0)
        myHrp.Velocity = Vector3.new(0, 0, 0)
    elseif IsFlinging then
        IsFlinging = false
        task.wait(0.05)
        if OriginalCFrame and myHrp then myHrp.CFrame = OriginalCFrame end
    end
end)

