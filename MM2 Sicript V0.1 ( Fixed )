local function RefreshTpList()
    for _, child in pairs(TpScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local btn = Instance.new("TextButton", TpScroll)
            btn.Size = UDim2.new(1, -8, 0, 28)
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
            btn.Font = Enum.Font.Gotham
            btn.Text = p.DisplayName
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextSize = 12
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            btn.MouseButton1Click:Connect(function()
                SelectedTpPlayer = p
                TpSelLabel.Text = "Seçili: " .. p.DisplayName
            end)
        end
    end
    TpScroll.CanvasSize = UDim2.new(0, 0, 0, #Players:GetPlayers() * 32)
end

