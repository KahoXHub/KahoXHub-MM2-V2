    -- Silahı doğrudan veya harita klasörlerinin içinde derinlemesine ara
    local gunDrop = Workspace:FindFirstChild("GunDrop") or Workspace:FindFirstChild("GunDrop", true)
    if not gunDrop then
        for _, v in pairs(Workspace:GetDescendants()) do
            if v.Name == "GunDrop" then gunDrop = v break end
        end
    end
    
    -- Eğer silah bulunduysa ve karakterimiz yaşıyorsa
    if gunDrop and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        hrp.Velocity = Vector3.new(0, 0, 0) -- Hız ivmesini sıfırla (Geri fırlatmasın)
        
        -- Silah modelinin ana parçası varsa onun 3 birim yukarısına, yoksa pivotun 3 birim yukarısına güvenle ışınla
        if gunDrop:IsA("Model") and gunDrop.PrimaryPart then
            hrp.CFrame = gunDrop.PrimaryPart.CFrame + Vector3.new(0, 3, 0)
        else
            hrp.CFrame = gunDrop:GetPivot() + Vector3.new(0, 3, 0)
        end
    end
end)

